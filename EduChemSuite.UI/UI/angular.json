    },
    "equation-balancer": {
      "projectType": "library",
      "root": "projects/equation-balancer",
      "sourceRoot": "projects/equation-balancer/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/equation-balancer/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/equation-balancer/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/equation-balancer/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    },
    "electron-config": {
      "projectType": "library",
      "root": "projects/electron-config",
      "sourceRoot": "projects/electron-config/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/electron-config/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/electron-config/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/electron-config/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    },
    "periodic-table-quiz": {
      "projectType": "library",
      "root": "projects/periodic-table-quiz",
      "sourceRoot": "projects/periodic-table-quiz/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {

      }
    },
    "stoichiometry-stepper": {
      "projectType": "library",
      "root": "projects/stoichiometry-stepper",
      "sourceRoot": "projects/stoichiometry-stepper/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/stoichiometry-stepper/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/stoichiometry-stepper/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/stoichiometry-stepper/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  },
  "cli": {
    "analytics": false
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}

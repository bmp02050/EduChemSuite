# Copy this file to .env and fill in your values
# cp .env.example .env

# ===== Database =====
POSTGRES_DB=educhemsuite
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ===== JWT =====
# Production: https://educhemsuite.ddns.net/
JWT_ISSUER=https://www.educhemsuite.com/
JWT_AUDIENCE=https://www.educhemsuite.com/
JWT_KEY=your-secret-key-here-make-it-long-and-random

# ===== Frontend URL (for CORS - no trailing slash) =====
# Production: https://educhemsuite.ddns.net
FRONTEND_URL=http://localhost

# ===== Email (optional) =====
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_ENABLE_SSL=true
